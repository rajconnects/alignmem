{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alignmink.ai/schema/dtp-v0.1.json",
  "title": "Alignmink Decision Trace Protocol v0.1",
  "description": "Canonical schema for a single decision trace per the Alignmink Decision Trace Protocol (DTP) v0.1. See PROTOCOL.md for the full normative specification.",
  "type": "object",
  "required": [
    "schema_version",
    "trace_id",
    "title",
    "captured_at",
    "author",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol version. MUST be \"0.1.0\" for traces conforming to this version."
    },
    "trace_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]{1,80}$",
      "description": "Unique per author. Format: YYYY-MM-DD-<lowercase-slug>."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Display headline. Plain text, no markdown."
    },
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 with explicit timezone designator (Z or numeric offset). Local time without offset is not allowed."
    },
    "author": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "role": { "type": "string", "minLength": 1 },
        "id": { "type": "string" }
      }
    },
    "decision": {
      "type": "object",
      "description": "The committed decision. v0.1.0: only `statement` is required. Earlier drafts included `reasoning` and `alternatives` here; both are deprecated in favor of nodes[] (§5.8 of PROTOCOL.md). Legacy traces with these fields still validate (additionalProperties true) but new producers SHOULD NOT emit them.",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string", "minLength": 1, "maxLength": 500 },
        "reasoning": {
          "type": "string",
          "deprecated": true,
          "description": "DEPRECATED. Use nodes[] (resolution node content) instead."
        },
        "alternatives": {
          "type": "array",
          "deprecated": true,
          "description": "DEPRECATED. Use nodes[] of node_type 'response' instead.",
          "items": {
            "type": "object",
            "properties": {
              "option": { "type": "string" },
              "rejected_because": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "description": "Canonical deliberation array. Multi-author intent → response → dissent → resolution turns. Aligns 1:1 with V1 SaaS decision_nodes table.",
      "items": {
        "type": "object",
        "required": ["id", "node_type", "author_role", "author_name", "content", "sequence_order", "created_at"],
        "properties": {
          "id": { "type": "string" },
          "node_type": {
            "type": "string",
            "description": "Recommended values: intent | response | question | dissent | resolution. Open string — vocabulary may evolve."
          },
          "author_role": {
            "type": "string",
            "description": "Recommended values: founder, ceo, coo, cpo, cto, cfo, vp_*, chief_of_staff, advisor, team_member. Open string."
          },
          "author_name": { "type": "string", "minLength": 1 },
          "content": { "type": "string", "minLength": 1 },
          "context": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "source": { "type": "string" },
              "session": { "type": "string" },
              "related_topics": { "type": "array", "items": { "type": "string" } }
            }
          },
          "sequence_order": { "type": "integer", "minimum": 1 },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "thread_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{1,80}$",
      "description": "Optional virtual grouping. Traces sharing a thread_id form a thread."
    },
    "session_id": {
      "type": "string",
      "description": "Optional reference to a session file."
    },
    "captured_via": {
      "type": "string",
      "enum": ["claude-code", "claude-chat", "cowork", "chatgpt", "cli-direct", "other"],
      "description": "Surface where capture occurred. Default: 'other'."
    },
    "status": {
      "type": "string",
      "enum": ["open", "resolved", "contested", "deferred", "superseded"],
      "default": "open"
    },
    "themes": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 40 },
      "description": "Stakeholder-oriented grouping. Recommended starter vocabulary: board, investors, customers, team, hiring, suppliers, partners, regulators, media, competitors, internal, legal, finance."
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "Optional integrity fingerprint. SHA-256 over canonical-JSON of trace_id + title + captured_at + author.{name,role} + decision.{statement,reasoning,alternatives}."
    },
    "revisit_triggers": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "impact": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target_trace_id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["supersedes", "contradicts", "depends_on", "enables", "revisits", "extends"]
          },
          "target_trace_id": { "type": "string" },
          "note": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "value"],
        "properties": {
          "kind": { "type": "string", "enum": ["url", "file_path", "inline_text"] },
          "value": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "outcome": {
      "type": "object",
      "properties": {
        "observed_at": { "type": ["string", "null"], "format": "date-time" },
        "observation": { "type": ["string", "null"], "maxLength": 2000 },
        "success": { "type": ["boolean", "null"] }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Vendor-specific fields, namespaced by reverse-DNS. Keys MUST follow reverse-DNS format (e.g., com.alignmink.war-cabinet).",
      "patternProperties": {
        "^[a-z][a-z0-9]+(\\.[a-z][a-z0-9-]*)+$": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
