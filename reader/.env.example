# Alignmem Trace Reader — local config
# Copy to .env and fill in (never commit .env)

# Server port (Express)
PORT=3000

# Optional: set a passcode via env (otherwise first-run UI will prompt to create one)
# PASSCODE=change-me

# Cookie signing secret — auto-generated on first run if omitted.
# COOKIE_SECRET=auto-generated-on-first-run

# Where the reader stores its state (bcrypt hash, cookie secret, project list)
# Defaults to ~/.alignmem-reader
# ALIGNMEM_HOME=/Users/you/.alignmem-reader
